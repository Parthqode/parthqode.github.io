</div>

<script>
(function(){
  var RAMPS = {
    Error:   {50:'#fee7e9',100:'#feced2',200:'#fdbac1',300:'#fda5af',400:'#f77386',500:'#f1425d',600:'#d72c50',700:'#bb153a',800:'#9d1438',900:'#720d2a',950:'#4b0619'},
    Success: {50:'#f1fae9',100:'#e3f5d2',200:'#c4e9a6',300:'#a4dd7a',400:'#94d464',500:'#84cc4f',600:'#649e34',700:'#438519',800:'#33561e',900:'#21401a',950:'#14290b'},
    Warning: {50:'#fff8e9',100:'#fff2d3',200:'#ffdfa0',300:'#ffca6d',400:'#ffab39',500:'#ff8c07',600:'#e66f06',700:'#c65306',800:'#973907',900:'#6f2a05',950:'#471903'},
    Neutral: {white:'#fcfcfc', ink:'#0c0d10'}
  };
  var ORDER = ['Error','Success','Warning','Neutral'];

  function lin(c){ c/=255; return c<=0.03928 ? c/12.92 : Math.pow((c+0.055)/1.055,2.4); }
  function lum(h){ return 0.2126*lin(parseInt(h.slice(1,3),16))+0.7152*lin(parseInt(h.slice(3,5),16))+0.0722*lin(parseInt(h.slice(5,7),16)); }
  function ratio(a,b){ var x=lum(a),y=lum(b); return (Math.max(x,y)+0.05)/(Math.min(x,y)+0.05); }

  var base=null, baseName=null, baseFam=null, comp='button', role='bg';
  var picker=document.getElementById('ccPicker');

  document.getElementById('ccComp').addEventListener('change', function(){ comp=this.value; if(base) render(); });
  document.getElementById('ccRole').addEventListener('click', function(e){ var b=e.target.closest('button'); if(!b)return;
    this.querySelectorAll('button').forEach(function(x){x.classList.remove('on');}); b.classList.add('on'); role=b.dataset.role; if(base) render(); });

  ORDER.forEach(function(fam){
    var row=document.createElement('div'); row.className='cc-row';
    var rl=document.createElement('div'); rl.className='rl'; rl.textContent=fam; row.appendChild(rl);
    Object.keys(RAMPS[fam]).forEach(function(step){
      var hex=RAMPS[fam][step];
      var sw=document.createElement('button'); sw.className='cc-sw'; sw.style.background=hex; sw.title=fam+' '+step+' · '+hex;
      var s=document.createElement('span'); s.textContent=step; s.style.color = lum(hex)<0.4 ? '#fff':'#0c0d10';
      sw.appendChild(s);
      sw.addEventListener('click', function(){ pick(fam,step,hex,sw); });
      row.appendChild(sw);
    });
    picker.appendChild(row);
  });

  function pick(fam,step,hex,el){
    document.querySelectorAll('.cc-sw').forEach(function(x){x.classList.remove('sel');});
    el.classList.add('sel'); base=hex; baseName=fam+' '+step; baseFam=fam; render();
  }

  function chip(fam,step,hex,r,level,kind){
    var d=document.createElement('div'); d.className='cc-chip';
    var cs=document.createElement('div'); cs.className='cs'; cs.style.background=hex;
    var t=document.createElement('div');
    var n=document.createElement('div'); n.className='ct'; n.textContent=fam+' '+step;
    var meta=document.createElement('div'); meta.className='cc-meta';
    var rr=document.createElement('span'); rr.className='cr'; rr.textContent=r.toFixed(2)+':1';
    var pl=document.createElement('span'); pl.className='pill '+(level==='AAA'?'aaa':level==='AA'?'aa':'ui'); pl.textContent=level;
    meta.appendChild(rr); meta.appendChild(pl);
    t.appendChild(n); t.appendChild(meta);
    d.appendChild(cs); d.appendChild(t);
    d.appendChild(kind==='ui' ? uiPreview(hex) : preview(hex));
    return d;
  }

  // TEXT preview: base + suggested color as text, honoring role
  function preview(hex){
    var roleBg=(role==='bg');
    var bg = roleBg ? base : hex;
    var fg = roleBg ? hex  : base;
    var p=document.createElement('div'); p.className='cc-prev';
    var el=document.createElement('div');
    if(comp==='button'){ p.style.background='var(--n-50)'; el.style.cssText='font:600 11px/14px var(--font);padding:5px 10px;border-radius:6px;background:'+bg+';color:'+fg+';border:1px solid '+(roleBg?bg:fg); el.textContent='Button'; }
    else if(comp==='toast'){ p.style.background=bg; el.style.cssText='font:700 11px/14px var(--font);color:'+fg; el.textContent='● Toast'; }
    else { p.style.background=bg; el.style.cssText='font:600 11px/14px var(--font);color:'+fg; el.textContent='ⓘ Message'; }
    p.appendChild(el); return p;
  }

  // UI preview: shows the suggested color used as an ICON, a BORDER and a FILL chip — not as text
  function uiPreview(hex){
    // the UI element color is whichever is NOT the base surface
    var roleBg=(role==='bg');
    var surface = roleBg ? base : '#fcfcfc';
    var ink = hex;                       // icon / border / fill color being tested
    var p=document.createElement('div'); p.className='cc-prev cc-prev-ui'; p.style.background=surface;
    p.innerHTML =
      '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="'+ink+'" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" title="icon"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16v.01"/></svg>'+
      '<span style="display:inline-block;width:24px;height:16px;border-radius:4px;border:1.5px solid '+ink+'" title="border"></span>'+
      '<span style="display:inline-block;width:16px;height:16px;border-radius:4px;background:'+ink+'" title="fill"></span>';
    return p;
  }

  function render(){
    document.getElementById('ccResult').hidden=false;
    document.getElementById('ccPickName').textContent=baseName;
    document.getElementById('ccPickHex').textContent=base;
    var fine=document.getElementById('ccFine'), body=document.getElementById('ccBody'),
        large=document.getElementById('ccLarge'), ui=document.getElementById('ccUi');
    fine.innerHTML=''; body.innerHTML=''; large.innerHTML=''; ui.innerHTML='';
    // only suggest from the same palette as the selected color, plus Neutral
    ORDER.filter(function(fam){ return fam===baseFam || fam==='Neutral'; })
      .forEach(function(fam){ Object.keys(RAMPS[fam]).forEach(function(step){
      var hex=RAMPS[fam][step]; if(hex.toLowerCase()===base.toLowerCase()) return;
      var r=ratio(base,hex);
      // fine print / disclaimers (small text → AAA, needs >= 7:1)
      if(r>=7) fine.appendChild(chip(fam,step,hex,r,'AAA'));
      // body & small text
      if(r>=4.5) body.appendChild(chip(fam,step,hex,r, r>=7?'AAA':'AA'));
      // headings & large text
      if(r>=3) large.appendChild(chip(fam,step,hex,r, r>=4.5?'AAA':'AA'));
      // UI / icons / borders
      if(r>=3) ui.appendChild(chip(fam,step,hex,r,'UI','ui'));
    }); });
    [fine,body,large,ui].forEach(function(b){ if(!b.children.length){ var e=document.createElement('div'); e.className='cc-empty'; e.textContent='None — try a lighter or darker shade.'; b.appendChild(e); } });

    // ---- preview reflects component + role ----
    var roleBg = (role==='bg');
    var partner = bestPartner();           // highest-contrast color from same palette + neutral
    var bg = roleBg ? base : (partner?partner.hex:'#fcfcfc');
    var fg = roleBg ? (partner?partner.hex:'#0c0d10') : base;
    var pv=document.getElementById('ccPreview'); pv.innerHTML='';
    var el=document.createElement('div');
    if(comp==='button'){ pv.style.background='var(--n-50)'; el.style.cssText='font:600 13px/18px var(--font);padding:9px 16px;border-radius:8px;background:'+bg+';color:'+fg+';border:1px solid '+(roleBg?bg:fg); el.textContent='Button'; }
    else if(comp==='toast'){ pv.style.background=bg; el.style.cssText='font:700 13px/18px var(--font);color:'+fg; el.textContent='● Toast'; }
    else { pv.style.background=bg; el.style.cssText='font:600 13px/18px var(--font);color:'+fg; el.textContent='ⓘ Message'; }
    pv.appendChild(el);

    // ---- hint ----
    var n=body.querySelectorAll('.cc-chip').length;
    var where = roleBg ? 'background' : 'text / icon';
    var msg='Using <b>'+baseName+'</b> as the <b>'+where+'</b> of a '+comp+'. ';
    if(roleBg) msg += n ? 'Put any of the <b>'+n+'</b> body-text color(s) below on top of it.' : 'No same-palette color is readable as body text on it — use it for large text, icons or borders only.';
    else msg += n ? 'It reads as body text on any of the <b>'+n+'</b> surface(s) below.' : 'It is not readable as body text on any same-palette surface — reserve it for large text, icons or borders.';
    document.getElementById('ccHint').innerHTML=msg;
  }

  function bestPartner(){
    var best=null;
    ORDER.filter(function(f){ return f===baseFam || f==='Neutral'; }).forEach(function(fam){
      Object.keys(RAMPS[fam]).forEach(function(step){ var hex=RAMPS[fam][step];
        if(hex.toLowerCase()===base.toLowerCase())return; var r=ratio(base,hex);
        if(!best||r>best.r) best={hex:hex,r:r}; }); });
    return best;
  }
})();
</script>
